# Site
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Sanity (https://www.sanity.io/manage — Project ID & dataset)
NEXT_PUBLIC_SANITY_PROJECT_ID=yourProjectId
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Server-only: create token with Editor permissions at sanity.io/manage → API → Tokens
# Required for POST /api/contact (creates contactSubmission documents)
SANITY_API_WRITE_TOKEN=
